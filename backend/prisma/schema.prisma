// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}


model User {
  id                  String    @id @default(cuid())
  fullName            String
  location            String
  subLocation         String
  phone               String @unique
  verificationCode    String?
  isVerified         Boolean   @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model UserVolunteer {
  id                  String    @id @default(cuid())
  firstName           String    
  lastName            String
  email               String   
  phone               String
  location            String
  subLocation         String
  message             String  @default("") @db.VarChar(3000)
  privacyPolicy       Boolean

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id                  String    @id @default(cuid())
  merchantRequestID   String
  checkoutRequestID   String
  phoneNumber          String
  amount               Decimal   @db.Decimal(10, 2)
  mpesaReceiptNumber   String?
  accountReference     String?
  transactionDate      DateTime?
  status               String    // 'success', 'failed', 'pending'
  resultCode           Int
  resultDesc           String
  errorMessage         String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([phoneNumber])
  @@index([status])
  @@index([merchantRequestID])
  @@index([checkoutRequestID])
}

model ExpoRegistration {
  id               String   @id @default(cuid())
  groupName        String
  designation      String   // 'Official' or 'Member'
  groupLeaderName  String
  yourName         String
  idNumber         String
  phoneNumber      String
  isVerified       Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SchedulingAvailability {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0 = Sunday
  startTime String   // UTC start of availability, e.g. "09:00"
  endTime   String   // UTC end of availability, e.g. "17:00"

  bookings  SchedulingBooking[] @relation("AvailabilityBookings")
}

model SchedulingBooking {
  id             String   @id @default(uuid())
  name           String
  email          String
  startTime      DateTime // UTC
  endTime        DateTime // UTC, always 1 hour after startTime
  meetLink       String?
  googleEventId  String?
  status         String   // pending | confirmed | expired | cancelled
  expiresAt      DateTime?
  stripeSessionId String? @unique

  availabilityId String
  availability   SchedulingAvailability @relation("AvailabilityBookings", fields: [availabilityId], references: [id])

  payment   SchedulingPayment?
  createdAt DateTime @default(now())

  @@unique([availabilityId, startTime])
}

model SchedulingPayment {
  id        String   @id @default(uuid())
  bookingId String   @unique
  stripeId  String
  amount    Int
  status    String   // pending | paid

  booking SchedulingBooking @relation(fields: [bookingId], references: [id])
}

model GoogleOAuthToken {
  id           String   @id @default(uuid())
  provider     String   @unique // "google"
  refreshToken String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  asset       String
  assignedTo  String
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([asset])
  @@index([assignedTo])
  @@index([status])
  @@index([createdAt])
}

