// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum VolunteerRole {
  POLLING_AGENT
  BLOGGING_TEAM
  VOTER
}

enum Gender {
  MALE
  FEMALE
}

model User {
  id                  String    @id @default(cuid())
  fullName            String
  location            String
  subLocation         String
  phone               String @unique
  verificationCode    String?
  isVerified         Boolean   @default(false)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model UserVolunteer {
  id                  String    @id @default(cuid())
  fullName            String    @default("")
  idNumber            String    @default("")
  ward                String    @default("")
  role                VolunteerRole @default(POLLING_AGENT)
  gender              Gender    @default(MALE)
  phone               String
  location            String
  subLocation         String
  pollingStation      String    @default("")
  message             String  @default("") @db.VarChar(3000)
  privacyPolicy       Boolean

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id                  String    @id @default(cuid())
  merchantRequestID   String
  checkoutRequestID   String
  phoneNumber          String
  amount               Decimal   @db.Decimal(10, 2)
  mpesaReceiptNumber   String?
  accountReference     String?
  transactionDate      DateTime?
  status               String    // 'success', 'failed', 'pending'
  resultCode           Int
  resultDesc           String
  errorMessage         String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([phoneNumber])
  @@index([status])
  @@index([merchantRequestID])
  @@index([checkoutRequestID])
}

model ExpoRegistration {
  id               String   @id @default(cuid())
  groupName        String
  designation      String   // 'Official' or 'Member'
  groupLeaderName  String
  yourName         String
  idNumber         String
  phoneNumber      String
  isVerified       Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SchedulingAvailability {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0 = Sunday
  startTime String   // UTC start of availability, e.g. "09:00"
  endTime   String   // UTC end of availability, e.g. "17:00"

  bookings  SchedulingBooking[] @relation("AvailabilityBookings")
}

model SchedulingBooking {
  id             String   @id @default(uuid())
  name           String
  email          String
  notes          String?  @db.Text
  startTime      DateTime // UTC
  endTime        DateTime // UTC, always 1 hour after startTime
  meetLink       String?
  googleEventId  String?
  status         String   // pending | confirmed | expired | cancelled
  expiresAt      DateTime?
  stripeSessionId String? @unique
  appSource      String   @default("phd-success") // phd-success | rise

  availabilityId String
  availability   SchedulingAvailability @relation("AvailabilityBookings", fields: [availabilityId], references: [id])

  payment      SchedulingPayment?
  invite       SchedulingInvite?
  attachments  SchedulingBookingAttachment[]
  sessionCreditUsage SchedulingSessionCreditUsage?
  createdAt    DateTime @default(now())
  emailsSentAt DateTime?

  @@unique([availabilityId, startTime])
}

model SchedulingBookingAttachment {
  id           String    @id @default(uuid())
  bookingId    String?
  booking      SchedulingBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  uploadToken  String?   @unique
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
}

model SchedulingInvite {
  id        String    @id @default(uuid())
  email     String
  type      String    // paid | free | package
  expiresAt DateTime?
  usedAt    DateTime?
  bookingId String?   @unique
  createdAt DateTime  @default(now())

  booking       SchedulingBooking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  sessionCredit SchedulingSessionCredit?
}

model SchedulingSessionCredit {
  id            String   @id @default(uuid())
  email         String
  appSource     String   @default("phd-success")
  totalSessions Int
  usedSessions  Int      @default(0)
  notes         String?  @db.Text
  inviteId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invite SchedulingInvite?              @relation(fields: [inviteId], references: [id])
  usages SchedulingSessionCreditUsage[]

  @@unique([email, appSource])
  @@index([email, appSource])
}

model SchedulingSessionCreditUsage {
  id        String   @id @default(uuid())
  creditId  String
  bookingId String   @unique
  createdAt DateTime @default(now())

  credit  SchedulingSessionCredit @relation(fields: [creditId], references: [id])
  booking SchedulingBooking       @relation(fields: [bookingId], references: [id])
}

model SchedulingPayment {
  id        String   @id @default(uuid())
  bookingId String   @unique
  stripeId  String
  amount    Int
  status    String   // pending | paid

  booking SchedulingBooking @relation(fields: [bookingId], references: [id])
}

model GoogleOAuthToken {
  id           String   @id @default(uuid())
  provider     String   @unique // "google"
  refreshToken String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  asset       String
  assignedTo  String
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([asset])
  @@index([assignedTo])
  @@index([status])
  @@index([createdAt])
}

enum VaultRole {
  ADMIN
  GUEST
}

model VaultDocument {
  id           String   @id @default(uuid())
  title        String?
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  url          String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments VaultUserDocument[]

  @@index([createdAt])
}

model VaultUser {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String
  role      VaultRole @default(ADMIN)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  assignments VaultUserDocument[]
  sessions    VaultSession[]
}

model VaultSession {
  id          String   @id @default(uuid())
  token       String   @unique
  vaultUserId String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  vaultUser VaultUser @relation(fields: [vaultUserId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@index([vaultUserId])
}

model VaultUserDocument {
  id          String   @id @default(uuid())
  vaultUserId String
  documentId  String
  assignedAt  DateTime @default(now())

  vaultUser VaultUser     @relation(fields: [vaultUserId], references: [id], onDelete: Cascade)
  document  VaultDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([vaultUserId, documentId])
  @@index([vaultUserId])
  @@index([documentId])
}

